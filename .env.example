ANTHROPIC_API_KEY=sk-ant-tu-api-key-aqui

# ─── World Bank ──────────────────────────────────────────────────────────────
# No requiere token/API key. La API es 100% abierta y gratuita.
# Ya está configurada por defecto.

# ─── Banxico ─────────────────────────────────────────────────────────────────
# Token GRATUITO en: https://www.banxico.org.mx/SieAPIRest/service/v1/
# 1. Click en "Inicio de sesión" → regístrate con email
# 2. Ve a "Mi cuenta" → "Tokens" → genera uno
BANXICO_TOKEN=tu-token-banxico-aqui
