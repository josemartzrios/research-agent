# ─── Anthropic Claude ───────────────────────────────────────────────────────
# Obtén tu key en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-tu-api-key-aqui

# ─── INEGI ───────────────────────────────────────────────────────────────────
# Token GRATUITO en: https://www.inegi.org.mx/servicios/api_biinegi.html
# 1. Entra al link, llena el formulario de registro (nombre, email)
# 2. Te mandan el token por correo (tarda unos minutos)
INEGI_TOKEN=tu-token-inegi-aqui

# ─── Banxico ─────────────────────────────────────────────────────────────────
# Token GRATUITO en: https://www.banxico.org.mx/SieAPIRest/service/v1/
# 1. Click en "Inicio de sesión" → regístrate con email
# 2. Ve a "Mi cuenta" → "Tokens" → genera uno
BANXICO_TOKEN=tu-token-banxico-aqui
